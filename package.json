{
  "name": "canada-postal-codes",
  "version": "0.2.0",
  "description": "Fast, offline, zero-dependency lookups for Canadian postal codes.",
  "keywords": [
    "canada",
    "postal-code",
    "zip-code",
    "geocoding",
    "offline",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "build:data": "python scripts/build-data.py",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "bench": "tsx benchmarks/bench.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn build"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rezabanitaba/canada-postal-codes.git"
  },
  "homepage": "https://github.com/rezabanitaba/canada-postal-codes#readme",
  "bugs": {
    "url": "https://github.com/rezabanitaba/canada-postal-codes/issues"
  },
  "author": "Reza Banitaba <ahmadreza.banitaba@gmail.com>",
  "publishConfig": {
    "access": "public"
  }
}
